hostname: ""     # optional, defaults to os.Hostname()
server: http://127.0.0.1:8008
token: replace-with-unique-agent-token   # unique per agent; allow on Server with allow-token
region: SG
billing_period: "1m"        # 1m/3m/6m/12m, optional, for dashboard countdown and traffic reset
expires_at: "2026-08-15"    # YYYY-MM-DD, optional, next renewal date
interval: 30
tls_skip_verify: false       # true only for HTTPS with an untrusted/self-signed certificate
allow_plain_http: false      # required for HTTP to a non-loopback host (token is exposed in transit)
tcpping:
  - name: "CMv4"
    target: "sh-cm-v4.ip.zstaticcdn.com:80"
  - name: "CMv6"
    target: "sh-cm-v6.ip.zstaticcdn.com:80"
  - name: "CUv4"
    target: "sh-cu-v4.ip.zstaticcdn.com:80"
  - name: "CUv6"
    target: "sh-cu-v6.ip.zstaticcdn.com:80"
  - name: "CTv4"
    target: "sh-ct-v4.ip.zstaticcdn.com:80"
  - name: "CTv6"
    target: "sh-ct-v6.ip.zstaticcdn.com:80"
